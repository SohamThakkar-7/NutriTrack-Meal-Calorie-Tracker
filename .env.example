# ─────────────────────────────────────────────────────────────
# NutriTrack – .env.example  (Node.js / Express backend)
# Copy this to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (required for production):
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nutritrack?retryWrites=true&w=majority&appName=NutriTrack

# Port (leave empty on Render/Railway — they set it automatically):
PORT=5000

# Comma-separated allowed origins for CORS:
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://your-frontend-domain.com

# Environment: development | production
NODE_ENV=development
